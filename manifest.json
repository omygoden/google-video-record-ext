{
  "manifest_version": 3,
  "name": "AV Recorder Pro",
  "version": "1.0.0",
  "description": "Record video and audio in Chrome. Supports MP4 video and MP3/WAV audio export.",
  "permissions": [
    "downloads",
    "tabCapture"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AV Recorder Pro"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
